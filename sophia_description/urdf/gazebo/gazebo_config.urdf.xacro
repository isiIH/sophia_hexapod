<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="leg_gazebo_config" params="prefix">
        <!-- Reference the named collision directly so URDF→SDF places <surface>
             inside the correct <collision> element and not under <link>. -->
        <gazebo reference="${prefix}tibia_foot_collision">
          <surface>
            <bounce>
              <restitution_coefficient>0.0</restitution_coefficient>
              <threshold>0</threshold>
            </bounce>
            <friction>
              <bullet>
                <!-- Bullet Featherstone reads friction ONLY from <bullet> tag.  -->
                <!-- mu1/mu2 top-level and <ode><mu> are silently IGNORED.       -->
                <friction>0.3</friction>
                <friction2>0.3</friction2>
                <rolling_friction>0.0</rolling_friction>
              </bullet>
              <torsional>
                <coefficient>0.0</coefficient>
              </torsional>
            </friction>
            <contact>
              <bullet>
                <!-- split_impulse is CRITICAL to prevent violent yaw kicks -->
                <split_impulse>true</split_impulse>
                <split_impulse_penetration_threshold>-0.001</split_impulse_penetration_threshold>
              </bullet>
            </contact>
          </surface>
        </gazebo>

        <xacro:material_visual ref_link="${prefix}coxa_link" ambient="0.05 0.05 0.05 1.0" diffuse="0.1 0.1 0.1 1.0" specular="0.1 0.1 0.1 1.0"/>
        <xacro:material_visual ref_link="${prefix}femur_link" ambient="0.2 0.1 0.0 1.0" diffuse="1.0 0.4 0.0 1.0" specular="0.2 0.2 0.2 1.0"/>
        <xacro:material_visual ref_link="${prefix}tibia_link" ambient="0.05 0.05 0.05 1.0" diffuse="0.1 0.1 0.1 1.0" specular="0.1 0.1 0.1 1.0"/>
        
    </xacro:macro>
    
    <xacro:macro name="joint_gazebo" params="name">
        <joint name="${name}">
            <command_interface name="position">
                <param name="min">-1.57</param>
                <param name="max">1.57</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </xacro:macro>

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find sophia_controller)/config/sophia_controllers.yaml</parameters>
            <!-- Internal P-gain: velocity = P × error × update_rate.
                 At P=0.5, update_rate=100Hz: time_constant=20ms.
                 1.0 was too aggressive and caused bouncing. 0.25 was too sluggish. -->
            <position_proportional_gain>0.25</position_proportional_gain>
            <ros>
                <remapping>/controller_manager/robot_description:=/robot_description</remapping>
            </ros>
        </plugin>
    </gazebo>

    <xacro:material_visual ref_link="base_link" ambient="0.05 0.05 0.05 1.0" diffuse="0.1 0.1 0.1 1.0" specular="0.1 0.1 0.1 1.0"/>

    <ros2_control name="RobotSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <xacro:joint_gazebo name="rf_coxa_joint"/>
        <xacro:joint_gazebo name="rf_coxa_link_to_rf_femur_link"/>
        <xacro:joint_gazebo name="rf_femur_link_to_rf_tibia_link"/>
        <xacro:joint_gazebo name="rm_coxa_joint"/>
        <xacro:joint_gazebo name="rm_coxa_link_to_rm_femur_link"/>
        <xacro:joint_gazebo name="rm_femur_link_to_rm_tibia_link"/>
        <xacro:joint_gazebo name="rb_coxa_joint"/>
        <xacro:joint_gazebo name="rb_coxa_link_to_rb_femur_link"/>
        <xacro:joint_gazebo name="rb_femur_link_to_rb_tibia_link"/>
        <xacro:joint_gazebo name="lf_coxa_joint"/>
        <xacro:joint_gazebo name="lf_coxa_link_to_lf_femur_link"/>
        <xacro:joint_gazebo name="lf_femur_link_to_lf_tibia_link"/>
        <xacro:joint_gazebo name="lm_coxa_joint"/>
        <xacro:joint_gazebo name="lm_coxa_link_to_lm_femur_link"/>
        <xacro:joint_gazebo name="lm_femur_link_to_lm_tibia_link"/>
        <xacro:joint_gazebo name="lb_coxa_joint"/>
        <xacro:joint_gazebo name="lb_coxa_link_to_lb_femur_link"/>
        <xacro:joint_gazebo name="lb_femur_link_to_lb_tibia_link"/>

    </ros2_control>

</robot>